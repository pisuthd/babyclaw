{
  "name": "@tamago-labs/babyclaw-mcp-server",
  "version": "0.1.4",
  "description": "Model Context Protocol (MCP) server for BabyClaw agent using Tether Wallet Development Kit (WDK).",
  "keywords": [
    "wdk",
    "mcp",
    "wallet",
    "blockchain",
    "model-context-protocol"
  ],
  "author": "Pisuth",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamago-labs/babyclaw-mcp-server.git"
  },
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "setup": "node bin/index.js setup"
  },
  "bin": {
    "babyclaw-mcp-server": "./babyclaw/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "standard": {
    "ignore": [
      "types/**/*.d.ts",
      "examples/**/*.js",
      "tests/**/*.js"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "1.23.0",
    "@tetherto/wdk": "^1.0.0-beta.4",
    "@tetherto/wdk-indexer-http": "github:tetherto/wdk-indexer-http",
    "@tetherto/wdk-pricing-bitfinex-http": "^1.0.0-beta.1",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-protocol-fiat-moonpay": "^1.0.0-beta.1",
    "@tetherto/wdk-protocol-lending-aave-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-protocol-swap-velora-evm": "^1.0.0-beta.4",
    "@tetherto/wdk-wallet": "^1.0.0-beta.6",
    "@tetherto/wdk-wallet-btc": "^1.0.0-beta.6",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.10",
    "picocolors": "^1.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "jest": "30.1.3",
    "standard": "17.1.2",
    "typescript": "5.8.3"
  }
}
